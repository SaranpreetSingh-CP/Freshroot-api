generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User (Admin) ───────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Customer ───────────────────────────────────────────────────
model Customer {
  id            Int            @id @default(autoincrement())
  name          String
  phone         String
  email         String?
  address       String
  createdAt       DateTime        @default(now())
  subscriptions   Subscription[]
  orders          Order[]
  payments        Payment[]
  supportTickets  SupportTicket[]

  @@unique([phone, email])
}

// ─── Subscription ───────────────────────────────────────────────
model Subscription {
  id              Int            @id @default(autoincrement())
  customerId      Int
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            String         // STF, KG, KG + STF, Land, landscape
  package         String
  actualPrice     Float?
  offerPrice      Float
  paymentTerms    String?
  totalQuantity   Float?
  deliveredQty    Float?
  totalDeliveries Int?
  deliveredBasket Int?
  pendingKgs      Float?
  startDate       DateTime?
  endDate         DateTime?
  nextRenewal     DateTime?
  status          String         @default("active") // active, paused, expired, cancelled
  remarks         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deliveries      Delivery[]
  kitchenGarden   KitchenGarden?
}

// ─── Order ──────────────────────────────────────────────────────
model Order {
  id            String     @id @default(uuid())
  customerId    Int
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items         Json       // [{vegetableId?, name, quantity, unit}]
  totalAmount   Float
  cost          Float?     // calculated from vegetable prices
  status        String     @default("PENDING") // PENDING, CONFIRMED, PROCESSING, DELIVERED, CANCELLED, MISSED (computed only)
  deliveryDate  DateTime
  deliveredAt   DateTime?  // set when marked as delivered
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([deliveryDate])
}

// ─── Delivery ───────────────────────────────────────────────────
model Delivery {
  id             String        @id @default(uuid())
  subscriptionId Int
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  deliveredQty   Float
  date           DateTime
  status         String        @default("delivered") // scheduled, delivered, failed
  driverName     String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  supportTickets SupportTicket[]
}

// ─── Kitchen Garden (KG) ────────────────────────────────────────
model KitchenGarden {
  id               String        @id @default(uuid())
  subscriptionId   Int           @unique
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  setupDate        DateTime
  location         String?
  gardenSize       String?
  status           String        @default("active") // active, inactive, completed
  maintenanceCycle String?       // e.g. "monthly", "quarterly"
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  visits           KGVisit[]
}

// ─── KG Visit ───────────────────────────────────────────────────
model KGVisit {
  id              String        @id @default(uuid())
  kitchenGardenId String
  kitchenGarden   KitchenGarden @relation(fields: [kitchenGardenId], references: [id], onDelete: Cascade)
  visitDate       DateTime
  workDone        String
  healthStatus    String?
  photos          Json?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Expense ────────────────────────────────────────────────────
model Expense {
  id          String   @id @default(uuid())
  category    String
  description String
  amount      Float
  date        DateTime
  paidTo      String?
  receipt     String?
  billUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Payment ────────────────────────────────────────────────────
model Payment {
  id         String   @id @default(uuid())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Float
  method     String   @default("cash")
  status     String   @default("completed")
  reference  String?
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Support Ticket ─────────────────────────────────────────────
model SupportTicket {
  id            String           @id @default(uuid())
  customerId    Int?
  customer      Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deliveryId    String?
  delivery      Delivery?        @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  deliveryInfo  String?          // Display label when deliveryId is not a UUID
  issueType     String           // MISSING_ITEM, LATE_DELIVERY, QUALITY_ISSUE, OTHER
  description   String
  imageUrl      String?
  status        String           @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  messages      SupportMessage[]
}

// ─── Support Message ────────────────────────────────────────────
model SupportMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    String        // CUSTOMER, ADMIN
  message   String
  createdAt DateTime      @default(now())
}

// ─── Vegetable ──────────────────────────────────────────────────
model Vegetable {
  id           Int                       @id @default(autoincrement())
  name         String                    @unique
  hindiName    String
  category     String                    // SEASONAL, STAPLE, EXOTIC
  unit         String                    @default("kg") // kg, piece
  createdAt    DateTime                  @default(now())
  availability VegetableAvailability[]
  prices       VegetablePrice[]
}

// ─── Vegetable Availability ─────────────────────────────────────
model VegetableAvailability {
  id          Int       @id @default(autoincrement())
  vegetableId Int
  vegetable   Vegetable @relation(fields: [vegetableId], references: [id], onDelete: Cascade)
  month       Int       // 1-12

  @@unique([vegetableId, month])
}

// ─── Vegetable Price ────────────────────────────────────────────
model VegetablePrice {
  id          Int       @id @default(autoincrement())
  vegetableId Int
  vegetable   Vegetable @relation(fields: [vegetableId], references: [id], onDelete: Cascade)
  price       Float
  date        DateTime

  @@unique([vegetableId, date])
}

// ─── Lead / Quote Request ───────────────────────────────────────
model Lead {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  areaSize  String?  // e.g. "200 sq ft"
  planType  String?  // grow bag / land area
  message   String?
  status    String   @default("NEW") // NEW, CONTACTED, CONVERTED
  createdAt DateTime @default(now())
}
