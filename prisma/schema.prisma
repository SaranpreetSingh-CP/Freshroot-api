generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User (Admin) ───────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Customer ───────────────────────────────────────────────────
model Customer {
  id            Int            @id @default(autoincrement())
  name          String
  phone         String
  email         String?
  address       String
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  orders        Order[]
  payments      Payment[]
}

// ─── Subscription ───────────────────────────────────────────────
model Subscription {
  id              Int            @id @default(autoincrement())
  customerId      Int
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            String         // STF, KG, KG + STF, Land, landscape
  package         String
  actualPrice     Float?
  offerPrice      Float
  paymentTerms    String?
  totalQuantity   Float?
  deliveredQty    Float?
  totalDeliveries Int?
  deliveredBasket Int?
  pendingKgs      Float?
  startDate       DateTime?
  endDate         DateTime?
  nextRenewal     DateTime?
  status          String         @default("active") // active, paused, expired, cancelled
  remarks         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deliveries      Delivery[]
  kitchenGarden   KitchenGarden?
}

// ─── Order ──────────────────────────────────────────────────────
model Order {
  id            String     @id @default(uuid())
  customerId    Int
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items         Json       // [{name, qty, unit, price}]
  totalAmount   Float
  status        String     @default("pending") // pending, confirmed, dispatched, delivered, cancelled
  deliveryDate  DateTime
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ─── Delivery ───────────────────────────────────────────────────
model Delivery {
  id             String        @id @default(uuid())
  subscriptionId Int
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  deliveredQty   Float
  date           DateTime
  status         String        @default("delivered") // scheduled, delivered, failed
  driverName     String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ─── Kitchen Garden (KG) ────────────────────────────────────────
model KitchenGarden {
  id               String        @id @default(uuid())
  subscriptionId   Int           @unique
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  setupDate        DateTime
  location         String?
  gardenSize       String?
  status           String        @default("active") // active, inactive, completed
  maintenanceCycle String?       // e.g. "monthly", "quarterly"
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  visits           KGVisit[]
}

// ─── KG Visit ───────────────────────────────────────────────────
model KGVisit {
  id              String        @id @default(uuid())
  kitchenGardenId String
  kitchenGarden   KitchenGarden @relation(fields: [kitchenGardenId], references: [id], onDelete: Cascade)
  visitDate       DateTime
  workDone        String
  healthStatus    String?
  photos          Json?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Expense ────────────────────────────────────────────────────
model Expense {
  id          String   @id @default(uuid())
  category    String
  description String
  amount      Float
  date        DateTime
  paidTo      String?
  receipt     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Payment ────────────────────────────────────────────────────
model Payment {
  id         String   @id @default(uuid())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Float
  method     String   @default("cash")
  status     String   @default("completed")
  reference  String?
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
